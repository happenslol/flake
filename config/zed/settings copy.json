{
	"proxy": "",
	"ensure_final_newline_on_save": false,
	"remove_trailing_whitespace_on_save": false,
	"ui_font_weight": 400.0,

	"agent": { "play_sound_when_agent_done": "never" },
	"tab_size": 2,
	"auto_update": false,

	"show_signature_help_after_edits": true,
	"inline_code_actions": false,
	"show_completions_on_input": true,

	"git": {
		"inline_blame": { "enabled": false }
	},
	"soft_wrap": "editor_width",
	"format_on_save": "off",
	"scrollbar": { "show": "never" },
	"middle_click_paste": false,
	"ui_font_family": "IosevkaTerm Nerd Font Mono",
	"buffer_font_family": "IosevkaTerm Nerd Font Mono",
	"buffer_line_height": { "custom": 1.4 },
	"vim_mode": true,
	"ui_font_size": 18.0,
	"agent_ui_font_size": 18,
	"buffer_font_size": 16.0,
	"always_treat_brackets_as_autoclosed": true,
	"pane_split_direction_horizontal": "down",
	"pane_split_direction_vertical": "right",
	"icon_theme": {
		"mode": "dark",
		"dark": "Colored Zed Icons Theme Dark",
		"light": "Colored Zed Icons Theme Light"
	},
	"theme": {
		"mode": "dark",
		"light": "cozy night",
		"dark": "cozy night"
	},
	"lsp": {
		"nil": {
			"initialization_options": {
				"formatting": { "command": ["alejandra", "--quiet", "--"] }
			}
		}
	},
	"languages": {
		"Lua": {
			"formatter": {
				"external": {
					"command": "stylua",
					"arguments": ["--stdin-filepath", "{buffer_path}", "-"]
				}
			}
		},
		"TypeScript": {
			"formatter": "prettier",
			"code_actions_on_format": {
				"source.fixAll.eslint": true
			}
		},
		"TSX": {
			"formatter": "prettier",
			"code_actions_on_format": {
				"source.fixAll.eslint": true
			}
		},
		"Nix": { "language_servers": ["nil", "!nixd"] }
	},
	"restore_on_startup": "last_workspace",
	"when_closing_with_no_tabs": "keep_window_open",
	"current_line_highlight": "gutter",
	"project_panel": {
		"auto_reveal_entries": false,
		"hide_root": true,
		"hide_gitignore": false
	},
	"search": {
		"regex": true
	},
	"use_smartcase_search": true,
	"auto_install_extensions": {
		"colored-zed-icons-theme": true,
		"git-firefly": true,
		"graphql": true,
		"html": true,
		"lua": true,
		"nix": true,
		"toml": true
	}
}

{
  "agent_servers": {
    "claude-acp": {
      "default_config_options": {
        "effort": "high",
        "mode": "auto"
      },
      "type": "registry"
    },
    "pi-acp": {
      "type": "registry"
    }
  },
  "buffer_line_height": "standard",
  "agent_buffer_font_size": 18.0,
  "agent_ui_font_size": 18.0,
  "terminal": {
    "font_weight": 400.0
  },
  "vim_mode": true,
  "ui_font_size": 18,
  "buffer_font_size": 18,
  "ui_font_family": "Figtree",
  "buffer_font_family": "IosevkaTerm Nerd Font Mono",
  "theme": {
    "light": "cozy night",
    "dark": "cozy night",
  },

  "pane_split_direction_horizontal": "down",
  "pane_split_direction_vertical": "right",

  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
}

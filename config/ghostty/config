# Font
font-family = IosevkaTerm Nerd Font
font-size = 12

# Cursor
cursor-color = #ECEFF1
cursor-text = #212121
cursor-style = block
cursor-style-blink = false
shell-integration-features = no-cursor

# Mouse
mouse-hide-while-typing = true

# Bell
bell-features = no-audio,no-system,no-attention,no-title,no-border

# Window
window-padding-x = 2
window-padding-y = 2
window-decoration = none
confirm-close-surface = false
resize-overlay = never
gtk-tabs-location = bottom
gtk-wide-tabs = false
gtk-custom-css = style.css

# Colors
foreground = #EEFFFF
background = #212121

selection-foreground = #EEFFFF
selection-background = #444444

# black
palette = 0=#2B2B2B
palette = 8=#4F4F4F

# red
palette = 1=#F07178
palette = 9=#FF8B92

# green
palette = 2=#C3E88D
palette = 10=#DDFFA7

# yellow
palette = 3=#FFCB6B
palette = 11=#FFE585

# blue
palette = 4=#82AAFF
palette = 12=#9CC4FF

# magenta
palette = 5=#C792EA
palette = 13=#E1ACFF

# cyan
palette = 6=#89DDFF
palette = 14=#A3F7FF

# white
palette = 7=#FFFFFF
palette = 15=#CCEEEE

# Split border
split-divider-color = #4F4F4F
unfocused-split-opacity = 0.85

# Clear default keybinds and set our own
keybind = clear

# Clipboard
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard

# Font size
keybind = ctrl+equal=reset_font_size
keybind = ctrl+plus=increase_font_size:1
keybind = ctrl+minus=decrease_font_size:1

# Reload config
keybind = ctrl+shift+f5=reload_config

# Fixterm sequences
keybind = ctrl+m=text:\x1b[109;5u
keybind = ctrl+i=text:\x1b[105;5u
keybind = ctrl+semicolon=text:\x1b[09;5u

# Tab management
keybind = ctrl+e>c=new_tab
keybind = ctrl+e>x=close_surface

keybind = ctrl+e>ctrl+l=move_tab:1
keybind = ctrl+e>ctrl+h=move_tab:-1

keybind = alt+one=goto_tab:1
keybind = alt+two=goto_tab:2
keybind = alt+three=goto_tab:3
keybind = alt+four=goto_tab:4
keybind = alt+five=goto_tab:5
keybind = alt+six=goto_tab:6
keybind = alt+seven=goto_tab:7
keybind = alt+eight=goto_tab:8
keybind = alt+nine=goto_tab:9

# Split management
keybind = ctrl+e>o=new_split:down
keybind = ctrl+e>u=new_split:right

keybind = ctrl+e>h=goto_split:left
keybind = ctrl+e>j=goto_split:bottom
keybind = ctrl+e>k=goto_split:top
keybind = ctrl+e>l=goto_split:right

# Split resizing
keybind = alt+k=resize_split:up,40
keybind = alt+j=resize_split:down,40
keybind = alt+h=resize_split:left,40
keybind = alt+l=resize_split:right,40

# Vim mode
keybind = ctrl+e>v=activate_key_table:vim

# Line movement
keybind = vim/j=scroll_page_lines:1
keybind = vim/k=scroll_page_lines:-1

# Page movement
keybind = vim/ctrl+d=scroll_page_down
keybind = vim/ctrl+u=scroll_page_up
keybind = vim/ctrl+f=scroll_page_down
keybind = vim/ctrl+b=scroll_page_up
keybind = vim/shift+j=scroll_page_down
keybind = vim/shift+k=scroll_page_up

# Jump to top/bottom
keybind = vim/g>g=scroll_to_top
keybind = vim/shift+g=scroll_to_bottom

# Search
keybind = vim/slash=start_search
keybind = vim/n=navigate_search:next

# Copy
keybind = vim/v=copy_to_clipboard
keybind = vim/y=copy_to_clipboard

# Command palette
keybind = vim/shift+semicolon=toggle_command_palette

# Exit vim mode
keybind = vim/escape=deactivate_key_table
keybind = vim/q=deactivate_key_table
keybind = vim/i=deactivate_key_table

# Catch unbound keys
keybind = vim/catch_all=ignore
